pkgname=yserver
pkgver=1.3.0.26.ga378936
pkgrel=1
pkgdesc="A modern X11 server written from scratch in Rust"
arch=('x86_64')
url="https://github.com/joske/yserver"
license=('MIT')
depends=(
  'fontconfig'
  'freetype2'
  'gcc-libs'
  'libinput'
  'libudev'
  'libxkbcommon'
  'libxshmfence'
  'seatd'
  'vulkan-icd-loader'
)
makedepends=(
  'cargo'
  'git'
  'pkgconf'
  'rust'
  'shaderc'
)
optdepends=(
  'just: use the project Justfile recipes'
)
source=("$pkgname::git+https://github.com/joske/yserver.git#branch=master")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$pkgname"
  git describe --tags 2>/dev/null | sed 's/^v//; s/-/./g' || echo "$pkgver"
}

build() {
  cd "$srcdir/$pkgname"
  # Unset CFLAGS to avoid GCC LTO bytecode in C static libraries;
  # the Rust linker uses lld which can't read GCC's LTO format.
  CFLAGS="" CXXFLAGS="" LTOFLAGS="" cargo build --release --bin yserver
}

check() {
  cd "$srcdir/$pkgname"
  CFLAGS="" CXXFLAGS="" LTOFLAGS="" cargo test --release -- \
    --skip kms::v2::backend::tests::v2_list_fonts_with_info_resolves_alias_to_xlfd_name \
    --skip kms::v2::composite_pool_ring::tests::release_of_already_free_slot_panics_in_debug
}

package() {
  cd "$srcdir/$pkgname"
  install -Dm755 target/release/yserver "$pkgdir/usr/bin/yserver"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
